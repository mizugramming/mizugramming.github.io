---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
---

<BaseLayout title="ホーム | mizugramming" titleEn="Home | mizugramming">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow" data-i18n-ja="ポートフォリオ" data-i18n-en="Portfolio">
          ポートフォリオ
        </p>
        <h1>mizugramming</h1>
        <p
          class="hero-lead"
          data-i18n-ja="データ分析・機械学習・シミュレーションで、改善案を検証可能な形にするポートフォリオ"
          data-i18n-en="A portfolio for turning data analysis, machine learning, and simulation into testable improvement plans"
        >
          データ分析・機械学習・シミュレーションで、改善案を検証可能な形にするポートフォリオ
        </p>
        <p
          data-i18n-ja="課題設定からモデル設計、検証実験、結果の解釈までを一貫して扱ったプロジェクトを整理しています。"
          data-i18n-en="This site organizes projects that connect problem framing, model design, validation experiments, and result interpretation."
        >
          課題設定からモデル設計、検証実験、結果の解釈までを一貫して扱ったプロジェクトを整理しています。
        </p>
        <div class="hero-actions">
          <a
            class="button"
            href="/projects"
            data-i18n-ja="プロジェクトを見る"
            data-i18n-en="View Projects"
          >
            プロジェクトを見る
          </a>
          <a
            class="button button-secondary"
            href="/research"
            data-i18n-ja="研究テーマを見る"
            data-i18n-en="Research Interests"
          >
            研究テーマを見る
          </a>
        </div>
      </div>

      <aside
        class="hero-panel"
        aria-label="主なテーマ"
        data-i18n-aria-label-ja="主なテーマ"
        data-i18n-aria-label-en="Main themes"
      >
        <h2 data-i18n-ja="主なテーマ" data-i18n-en="Main Themes">主なテーマ</h2>
        <ul class="theme-list">
          <li data-i18n-ja="シミュレーション設計" data-i18n-en="Simulation design">
            シミュレーション設計
          </li>
          <li data-i18n-ja="機械学習モデリング" data-i18n-en="Machine learning modeling">
            機械学習モデリング
          </li>
          <li data-i18n-ja="数理モデル化" data-i18n-en="Mathematical modeling">
            数理モデル化
          </li>
          <li data-i18n-ja="検証実験・評価指標" data-i18n-en="Validation and metrics">
            検証実験・評価指標
          </li>
          <li data-i18n-ja="Pythonによる分析実装" data-i18n-en="Python analysis implementation">
            Pythonによる分析実装
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="注目"
        eyebrowEn="Featured"
        title="代表プロジェクト"
        titleEn="Representative Projects"
        description="データから課題を見つけ、モデルを作り、改善案をシミュレーションで評価したプロジェクトです。"
        descriptionEn="Projects that identify issues from data, build models, and evaluate improvement plans through simulation."
      />

      <div class="card-grid">
        <ProjectCard
          title="統合シミュレータによる改善案の事前検証"
          titleEn="Pre-validating Improvement Plans with an Integrated Simulator"
          description="投球条件、打撃意思決定、コンタクト、飛距離をつなぐ機械学習・物理ハイブリッドモデルを設計しました。"
          descriptionEn="Designed a machine-learning and physics hybrid model that connects pitch conditions, batting decisions, contact, and flight distance."
          tags={["機械学習", "シミュレーション", "検証設計"]}
          tagsEn={["Machine Learning", "Simulation", "Validation Design"]}
          href="/projects/integrated-batting-simulator"
          status="卒業研究"
          statusEn="Thesis Project"
        />
        <ProjectCard
          title="マルコフ過程によるチーム力向上分析"
          titleEn="Team Performance Analysis with Markov Processes"
          description="状態空間と遷移確率を定義し、状況ごとの意思決定を比較することで得点期待値の改善を検証しました。"
          descriptionEn="Defined state spaces and transition probabilities to compare decisions by context and evaluate expected scoring improvements."
          tags={["数理モデル", "確率過程", "意思決定"]}
          tagsEn={["Mathematical Modeling", "Stochastic Processes", "Decision Making"]}
          href="/projects/team-performance-simulation"
          status="分析コンペ"
          statusEn="Analytics Competition"
        />
        <ProjectCard
          title="機械学習による数理問題へのアプローチ"
          titleEn="Machine Learning Approach to Mathematical Problems"
          description="NP困難な数理問題に対して、予測モデルと特徴量解釈から構造的な手がかりを探る研究テーマです。"
          descriptionEn="A research theme that uses prediction models and feature interpretation to seek structural clues in NP-hard mathematical problems."
          tags={["機械学習", "数理", "特徴量分析"]}
          tagsEn={["Machine Learning", "Mathematics", "Feature Analysis"]}
          href="/research"
          status="研究テーマ"
          statusEn="Research Theme"
        />
      </div>
    </div>
  </section>
</BaseLayout>
