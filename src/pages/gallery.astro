---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";

const galleryItems = [
  {
    title: "Simulation Result",
    description: "Placeholder for 1000-game simulation summaries.",
  },
  {
    title: "Graph",
    description: "Placeholder for visualizations and charts.",
  },
];
---

<BaseLayout title="Gallery | mizugramming">
  <section class="page-hero">
    <div class="container">
      <SectionTitle
        eyebrow="Gallery"
        title="Visual Gallery"
        description="Add GIFs, plots, simulation figures, and visual explanation images here."
      />
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <!-- Place images under public/assets/images or public/assets/gifs, then replace the placeholders. -->
      <div class="gallery-grid">
        <article class="gallery-card">
          <div class="open-campus-demo" aria-label="Open Campus pitch animation preview">
            <div class="demo-zone">
              <span class="demo-zone-line"></span>
              <span class="demo-zone-line"></span>
              <span class="demo-zone-line"></span>
              <span class="demo-zone-line"></span>
              <span class="demo-ball"></span>
              <span class="demo-impact"></span>
              <span class="demo-swing"></span>
              <span class="demo-contact demo-contact-one"></span>
              <span class="demo-contact demo-contact-two"></span>
              <span class="demo-contact demo-contact-three"></span>
            </div>
            <div class="demo-caption">
              <strong>Pitch Animation</strong>
              <span>Open_Campas prototype</span>
            </div>
          </div>
          <h3>Open Campus Pitch Animation</h3>
          <p>
            Trial preview based on the pitch and contact animation from
            <code>/home/ktbys/Open_Campas</code>.
          </p>
        </article>

        {galleryItems.map((item) => (
          <article class="gallery-card">
            <div class="visual-placeholder" aria-hidden="true">
              <span>{item.title}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
