---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";

const galleryItems = [
  {
    title: "シミュレーション結果",
    titleEn: "Simulation Result",
    description: "1000試合シミュレーションなどの集計結果を追加する予定です。",
    descriptionEn: "Placeholder for 1000-game simulation summaries.",
  },
  {
    title: "グラフ",
    titleEn: "Graph",
    description: "可視化画像や分析グラフを追加する予定です。",
    descriptionEn: "Placeholder for visualizations and charts.",
  },
];
---

<BaseLayout title="ギャラリー | mizugramming" titleEn="Gallery | mizugramming">
  <section class="page-hero">
    <div class="container">
      <SectionTitle
        eyebrow="ギャラリー"
        eyebrowEn="Gallery"
        title="ビジュアルギャラリー"
        titleEn="Visual Gallery"
        description="GIF、グラフ、シミュレーション図、説明用の画像を追加するページです。"
        descriptionEn="Add GIFs, plots, simulation figures, and visual explanation images here."
      />
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <!-- 画像はpublic/assets/images、GIFはpublic/assets/gifsに置いて差し替えます。 -->
      <div class="gallery-grid">
        <article class="gallery-card">
          <div
            class="open-campus-demo"
            aria-label="Open Campus 投球アニメーションのプレビュー"
            data-i18n-aria-label-ja="Open Campus 投球アニメーションのプレビュー"
            data-i18n-aria-label-en="Open Campus pitch animation preview"
          >
            <div class="demo-zone">
              <span class="demo-zone-line"></span>
              <span class="demo-zone-line"></span>
              <span class="demo-zone-line"></span>
              <span class="demo-zone-line"></span>
              <span class="demo-ball"></span>
              <span class="demo-impact"></span>
              <span class="demo-swing"></span>
              <span class="demo-contact demo-contact-one"></span>
              <span class="demo-contact demo-contact-two"></span>
              <span class="demo-contact demo-contact-three"></span>
            </div>
            <div class="demo-caption">
              <strong data-i18n-ja="投球アニメーション" data-i18n-en="Pitch Animation">
                投球アニメーション
              </strong>
              <span data-i18n-ja="Open_Campas プロトタイプ" data-i18n-en="Open_Campas prototype">
                Open_Campas プロトタイプ
              </span>
            </div>
          </div>
          <h3
            data-i18n-ja="Open Campus 投球アニメーション"
            data-i18n-en="Open Campus Pitch Animation"
          >
            Open Campus 投球アニメーション
          </h3>
          <p
            data-i18n-ja="/home/ktbys/Open_Campas の投球・コンタクト表現をもとにした試作プレビューです。"
            data-i18n-en="Trial preview based on the pitch and contact animation from /home/ktbys/Open_Campas."
          >
            <code>/home/ktbys/Open_Campas</code>
            の投球・コンタクト表現をもとにした試作プレビューです。
          </p>
        </article>

        {galleryItems.map((item) => (
          <article class="gallery-card">
            <div class="visual-placeholder" aria-hidden="true">
              <span data-i18n-ja={item.title} data-i18n-en={item.titleEn}>{item.title}</span>
            </div>
            <h3 data-i18n-ja={item.title} data-i18n-en={item.titleEn}>{item.title}</h3>
            <p data-i18n-ja={item.description} data-i18n-en={item.descriptionEn}>
              {item.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
