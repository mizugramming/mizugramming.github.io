---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
---

<BaseLayout title="自己紹介 | mizugramming" titleEn="About | mizugramming">
  <section class="page-hero">
    <div class="container">
      <SectionTitle
        eyebrow="自己紹介"
        eyebrowEn="About"
        title="自己紹介"
        titleEn="About Me"
        description="背景、関心分野、スキル、リンクを整理するページです。"
        descriptionEn="This page will introduce my background, interests, skills, and links."
      />
    </div>
  </section>

  <section class="section section-tight">
    <div class="container about-layout">
    <article class="content-block">
      <h3 data-i18n-ja="プロフィール" data-i18n-en="Profile">プロフィール</h3>
      
      <p data-i18n-ja="名前: 北林 瑞生" data-i18n-en="Name: Mizuki Kitabayashi">
        名前: 北林 瑞生
      </p>

      <p
        data-i18n-ja="現在所属: 熊本大学大学院 半導体・情報数理専攻"
        data-i18n-en="Current Affiliation: Graduate School of Kumamoto University, Department of Semiconductor and Informatics"
      >
        現在所属: 熊本大学大学院 半導体・情報数理専攻
      </p>

      <p
        data-i18n-ja="過去にデータを用いた分析や機械学習を用いた予測、シミュレータの作成などを行いました。現在の主題としては数学においてNP困難とされている問題に対して機械学習を用いた解決に向けてアプローチしております。数学者が頭を抱えている問題に対して積極的なアプローチを試みて分野の発展に貢献できればと考えております。"
        data-i18n-en="In the past, I have worked on data analysis, machine learning predictions, and creating simulators. My current research focuses on approaching NP-hard mathematical problems using machine learning. I aim to contribute to the field's development by actively tackling problems that mathematicians struggle with."
      >
        過去にデータを用いた分析や機械学習を用いた予測、シミュレータの作成などを行いました。現在の主題としては数学においてNP困難とされている問題に対して機械学習を用いた解決に向けてアプローチしております。数学者が頭を抱えている問題に対して積極的なアプローチを試みて分野の発展に貢献できればと考えております。
      </p>

      <p
        data-i18n-ja="将来的にはデータを用いて社会課題の解決やビジネス課題の解決など社会貢献を目的としてそれに付随する分野の学習を行っていきたい。"
        data-i18n-en="In the future, I want to use data to solve social and business issues, and I plan to continue learning in related fields to contribute to society."
      >
        将来的にはデータを用いて社会課題の解決やビジネス課題の解決など社会貢献を目的としてそれに付随する分野の学習を行っていきたい。
      </p>
    </article>

      <article class="content-block">
        <h3 data-i18n-ja="関心分野" data-i18n-en="Interests">関心分野</h3>
        <!-- 関心分野が具体化したら、このリストを編集します。 -->
        <ul class="plain-list">
          <li data-i18n-ja="野球シミュレーション" data-i18n-en="Baseball simulation">
            野球シミュレーション
          </li>
          <li data-i18n-ja="最適化" data-i18n-en="Optimization">最適化</li>
          <li data-i18n-ja="スポーツアナリティクス" data-i18n-en="Sports analytics">
            スポーツアナリティクス
          </li>
          <li data-i18n-ja="データ可視化" data-i18n-en="Data visualization">
            データ可視化
          </li>
          <li data-i18n-ja="Pythonプログラミング" data-i18n-en="Python programming">
            Pythonプログラミング
          </li>
        </ul>
      </article>

      <article class="content-block">
              <h3 data-i18n-ja="リンク" data-i18n-en="Links">リンク</h3>
              <ul class="plain-list links-list">
                <li>
                  <span class="link-label">GitHub:</span>
                  <a href="https://github.com/mizugramming" target="_blank" rel="noreferrer">
                    github.com/mizugramming
                  </a>
                </li>
                <li>
                  <span class="link-label">Atcoder:</span>
                  <a href="https://atcoder.jp/users/ktbys" target="_blank" rel="noreferrer">
                    atcoder.jp/users/ktbys
                  </a>
                </li>
                <li>
                  <span class="link-label">Kaggle:</span>
                  <a href="https://www.kaggle.com/kitabayashimizuki" target="_blank" rel="noreferrer">
                    kaggle.com/kitabayashimizuki
                  </a>
                </li>
              </ul>
      </article>
    </div>
  </section>
</BaseLayout>
