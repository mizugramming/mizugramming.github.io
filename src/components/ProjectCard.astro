---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  status?: string;
}

const { title, description, tags = [], href = "#", status = "Planned" } = Astro.props;
---

<article class="project-card">
  <div class="card-meta">
    <span class="status-label">{status}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>

  {tags.length > 0 && (
    <ul class="tag-list" aria-label={`${title} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}

  <a class="card-link" href={href}>View details</a>
</article>
